---
import experiences from "../data/experience.json";
---

<section class="section" id="trajectory">
  <div class="container">
    <h2 class="section-title">Trajetória Profissional</h2>

    <div class="timeline">
      {experiences.map((exp, i) => (
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-content comic-panel">
            <div class="company">{exp.company}</div>
            <div class="role">{exp.role}</div>
            <span class="period">{exp.period}</span>
            <p class="description">{exp.description}</p>
            <div class="timeline-techs">
              {exp.techs.map((tech) => (
                <span class="timeline-tech">{tech}</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="calvin-divider"></div>

    <div style="text-align: center; margin-top: 1rem;">
      <p style="font-family: var(--font-heading); font-size: 1.3rem; color: #888;">
        Quer saber mais? Vamos conversar!
      </p>
      <a href="#contact" class="btn-comic" style="margin-top: 1rem;">
        Entrar em Contato
      </a>
    </div>
  </div>
</section>
